#include <iostream>
#include <vector>
using namespace std;

class Graph {
    int V; // number of vertices
    vector<int> *adj; // adjacency list

public:
    // Constructor
    Graph(int V) {
        this->V = V;
        adj = new vector<int>[V];
    }

    // Add edge
    void addEdge(int u, int v) {
        adj[u].push_back(v);
        adj[v].push_back(u); // for undirected graph
    }

    // Display graph
    void display() {
        for (int i = 0; i < V; i++) {
            cout << i << " -> ";
            for (int j = 0; j < adj[i].size(); j++) {
                cout << adj[i][j] << " ";
            }
            cout << endl;
        }
    }
};

int main() {
    Graph g(4); // 4 vertices: 0,1,2,3

    g.addEdge(0, 1);
    g.addEdge(0, 2);
    g.addEdge(1, 3);

    cout << "Adjacency List Representation:\n";
    g.display();

    return 0;
}
